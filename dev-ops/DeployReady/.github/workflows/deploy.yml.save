name: Deploy Kora App

on:
  push:
    branches:
      - main

jobs:
  test:
    # Run tests before anything else
    name: Run Tests
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Install dependencies
        run: npm install --prefix app

      - name: Run tests
        run: npm test --prefix app

  build_and_push:
    # Build Docker image and push to registry
    name: Build & Push Docker Image
    needs: test
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Log in to GitHub Container Registry
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Build Docker image
        run: |
          docker build -t ghcr.io/${{ github.repository }}/kora-app:${{ github.sha }} .

      - name: Push Docker image
        run: |
          docker push ghcr.io/${{ github.repository }}/kora-app:${{ github.sha }}

  deploy:
    # Deploy to server via SSH
    name: Deploy to Server
    needs: build_and_push
    runs-on: ubuntu-latest

    steps:
      - name: SSH Deploy
        uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.SERVER_IP }}
          username: ${{ secrets.SERVER_USER }}
          key            docker stop kora-app || true
            docker rm kora-app || true
            docker run -d --name kora-app -p 80:3000 ghcr.io/${{ github.repository }}/kora-app:${{ github.sha }}
